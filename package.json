  },
  "license": "MIT",
  "homepage": "https://github.com/dependents/detective-typescript",
  "peerDependencies": {
    "typescript": "^5.4.4 || ^6.0.2"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.59.3",
    "ast-module-types": "github:dependents/node-ast-module-types#xmr/dev",
    "node-source-walk": "github:dependents/node-source-walk#xmr/dev"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "typescript": "^6.0.3",
    "uvu": "^0.5.6",
    "xo": "^2.0.2"
  }
}
