{
  "name": "detective-typescript",
  "version": "14.1.2",
  "author": "Patrik Henningsson <patrik.henningsson@gmail.com>",
  "description": "Get the dependencies of a TypeScript module",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "lint": "xo",
